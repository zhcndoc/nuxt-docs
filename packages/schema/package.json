{
  "name": "@nuxt/schema",
  "version": "5.0.0-0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/nuxt/nuxt.git",
    "directory": "packages/schema"
  },
  "description": "Nuxt types and default configuration",
  "homepage": "https://nuxt.com",
  "license": "MIT",
  "type": "module",
  "types": "./src/index.ts",
  "sideEffects": false,
  "exports": {
    ".": "./src/index.ts",
    "./builder-env": "./src/builder-env.ts",
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "schema",
    "builder-env.d.ts",
    "env.d.ts"
  ],
  "scripts": {
    "prepack": "tsdown",
    "build": "tsdown",
    "test:attw": "node ../../scripts/test-attw.ts"
  },
  "dependencies": {
    "@vue/shared": "catalog:build",
    "defu": "catalog:build",
    "nostics": "catalog:build",
    "pathe": "catalog:build",
    "pkg-types": "catalog:build",
    "std-env": "catalog:build"
  },
  "devDependencies": {
    "@types/pug": "catalog:dev",
    "@types/webpack-bundle-analyzer": "catalog:dev",
    "@types/webpack-hot-middleware": "catalog:dev",
    "@unhead/vue": "catalog:app-runtime",
    "@vitejs/plugin-vue": "catalog:vue",
    "@vitejs/plugin-vue-jsx": "catalog:dev",
    "@vue/compiler-core": "catalog:dev",
    "@vue/compiler-sfc": "catalog:vue",
    "@vue/language-core": "catalog:dev",
    "autoprefixer": "catalog:build",
    "c12": "catalog:build",
    "chokidar": "catalog:build",
    "compatx": "catalog:build",
    "css-minimizer-webpack-plugin": "catalog:webpack",
    "cssnano": "catalog:build",
    "esbuild": "catalog:dev",
    "esbuild-loader": "catalog:webpack",
    "h3": "catalog:dev",
    "hookable": "catalog:app-runtime",
    "ignore": "catalog:build",
    "mini-css-extract-plugin": "catalog:webpack",
    "ofetch": "catalog:app-runtime",
    "oxc-transform": "catalog:dev",
    "postcss": "catalog:build",
    "rollup-plugin-visualizer": "catalog:dev",
    "scule": "catalog:build",
    "tsdown": "catalog:dev",
    "unctx": "catalog:build",
    "unimport": "catalog:build",
    "untyped": "catalog:build",
    "vite": "catalog:vite",
    "vue": "catalog:app-runtime",
    "vue-bundle-renderer": "catalog:build",
    "vue-loader": "catalog:vue",
    "vue-router": "catalog:app-runtime",
    "webpack": "catalog:webpack",
    "webpack-dev-middleware": "catalog:webpack"
  },
  "engines": {
    "node": "^14.18.0 || >=16.10.0"
  },
  "publishConfig": {
    "exports": {
      ".": "./dist/index.mjs",
      "./builder-env": "./dist/builder-env.mjs",
      "./package.json": "./package.json"
    },
    "types": "./dist/index.d.mts"
  }
}
