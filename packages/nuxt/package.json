{
  "name": "nuxt",
  "version": "5.0.0-0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/nuxt/nuxt.git",
    "directory": "packages/nuxt"
  },
  "homepage": "https://nuxt.com",
  "description": "Nuxt is a free and open-source framework with an intuitive and extendable way to create type-safe, performant and production-grade full-stack web applications and websites with Vue.js.",
  "license": "MIT",
  "type": "module",
  "types": "./types.dev.d.ts",
  "bin": {
    "nuxi": "bin/nuxt.mjs",
    "nuxt": "bin/nuxt.mjs"
  },
  "exports": {
    ".": "./src/index.ts",
    "./config": {
      "types": "./config.d.ts",
      "import": "./config.js",
      "require": "./config.cjs"
    },
    "./schema": "./schema.js",
    "./kit": "./kit.js",
    "./meta": "./meta.js",
    "./app": "./src/app/index.ts",
    "./entry": "./src/runtime/server/entry.ts",
    "./manifest": "./src/runtime/server/manifest.ts",
    "./precomputed": "./src/runtime/server/precomputed.ts",
    "./styles": "./src/runtime/server/styles.ts",
    "./entry-chunk": "./src/runtime/server/entry-chunk.ts",
    "./entry-ids": "./src/runtime/server/entry-ids.ts",
    "./package.json": "./package.json"
  },
  "typesVersions": {
    "*": {
      "entry": [
        "./dist/runtime/server/entry.d.ts"
      ],
      "manifest": [
        "./dist/runtime/server/manifest.d.ts"
      ],
      "precomputed": [
        "./dist/runtime/server/precomputed.d.ts"
      ],
      "styles": [
        "./dist/runtime/server/styles.d.ts"
      ],
      "entry-chunk": [
        "./dist/runtime/server/entry-chunk.d.ts"
      ],
      "entry-ids": [
        "./dist/runtime/server/entry-ids.d.ts"
      ]
    }
  },
  "imports": {
    "#app": "./src/app/index.ts",
    "#app/nuxt": "./src/app/nuxt.ts",
    "#unhead/composables": "./src/head/runtime/composables.ts",
    "#pages/composables": "./src/pages/runtime/composables.ts"
  },
  "files": [
    "app.d.ts",
    "bin",
    "types.d.ts",
    "types.d.mts",
    "dist",
    "config.*",
    "kit.*",
    "meta.*",
    "schema.*"
  ],
  "scripts": {
    "prepack": "tsdown",
    "build": "tsdown",
    "test:attw": "node ../../scripts/test-attw.ts"
  },
  "dependencies": {
    "@dxup/nuxt": "catalog:build",
    "@nuxt/cli": "catalog:build",
    "@nuxt/devtools": "catalog:build",
    "@nuxt/kit": "workspace:*",
    "@nuxt/nitro-server": "workspace:*",
    "@nuxt/schema": "workspace:*",
    "@nuxt/telemetry": "catalog:build",
    "@nuxt/vite-builder": "workspace:*",
    "@unhead/vue": "catalog:app-runtime",
    "@vue/shared": "catalog:app-runtime",
    "chokidar": "catalog:build",
    "compatx": "catalog:build",
    "consola": "catalog:app-runtime",
    "cookie-es": "catalog:app-runtime",
    "defu": "catalog:app-runtime",
    "devalue": "catalog:app-runtime",
    "errx": "catalog:app-runtime",
    "escape-string-regexp": "catalog:build",
    "exsolve": "catalog:build",
    "fnv1a-64": "catalog:app-runtime",
    "hookable": "catalog:app-runtime",
    "ignore": "catalog:build",
    "impound": "catalog:build",
    "jiti": "catalog:build",
    "klona": "catalog:app-runtime",
    "knitwork": "catalog:build",
    "magic-string": "catalog:vite",
    "mlly": "catalog:build",
    "nanotar": "catalog:build",
    "nostics": "catalog:app-runtime",
    "object-identity": "catalog:app-runtime",
    "ofetch": "catalog:app-runtime",
    "ohash": "catalog:app-runtime",
    "on-change": "catalog:build",
    "oxc-walker": "catalog:vite",
    "pathe": "catalog:app-runtime",
    "perfect-debounce": "catalog:app-runtime",
    "picomatch": "catalog:build",
    "pkg-types": "catalog:build",
    "rolldown": "catalog:vite",
    "rolldown-string": "catalog:vite",
    "scule": "catalog:build",
    "std-env": "catalog:build",
    "tinyglobby": "catalog:build",
    "ufo": "catalog:app-runtime",
    "ultrahtml": "catalog:build",
    "uncrypto": "catalog:app-runtime",
    "unctx": "catalog:app-runtime",
    "undici": "catalog:build",
    "unhead": "catalog:app-runtime",
    "unimport": "catalog:build",
    "unplugin": "catalog:build",
    "unrouting": "catalog:build",
    "untyped": "catalog:build",
    "verkit": "catalog:build",
    "vue": "catalog:app-runtime",
    "vue-router": "catalog:app-runtime"
  },
  "devDependencies": {
    "@nuxt/scripts": "catalog:dev",
    "@parcel/watcher": "catalog:dev",
    "@types/estree": "catalog:dev",
    "@types/picomatch": "catalog:dev",
    "@vitejs/plugin-vue": "catalog:vue",
    "@vitejs/plugin-vue-jsx": "catalog:dev",
    "@vue/compiler-sfc": "catalog:vue",
    "tsdown": "catalog:dev",
    "typescript": "catalog:dev",
    "vite": "catalog:vite",
    "vitest": "catalog:dev",
    "vue-bundle-renderer": "catalog:build",
    "vue-sfc-transformer": "catalog:dev"
  },
  "peerDependencies": {
    "@parcel/watcher": "^2.1.0",
    "@types/node": ">=18.12.0"
  },
  "peerDependenciesMeta": {
    "@parcel/watcher": {
      "optional": true
    },
    "@types/node": {
      "optional": true
    }
  },
  "engines": {
    "node": "^22.19.0 || ^24.11.0 || >=26.0.0"
  },
  "publishConfig": {
    "exports": {
      ".": {
        "types": "./types.d.mts",
        "import": "./dist/index.mjs"
      },
      "./config": {
        "types": "./config.d.ts",
        "import": "./config.js",
        "require": "./config.cjs"
      },
      "./schema": "./schema.js",
      "./kit": "./kit.js",
      "./meta": "./meta.js",
      "./app": "./dist/app/index.js",
      "./entry": "./dist/runtime/server/entry.js",
      "./manifest": "./dist/runtime/server/manifest.js",
      "./precomputed": "./dist/runtime/server/precomputed.js",
      "./styles": "./dist/runtime/server/styles.js",
      "./entry-chunk": "./dist/runtime/server/entry-chunk.js",
      "./entry-ids": "./dist/runtime/server/entry-ids.js",
      "./package.json": "./package.json"
    },
    "imports": {
      "#app": "./dist/app/index.js",
      "#app/nuxt": "./dist/app/nuxt.js",
      "#unhead/composables": "./dist/head/runtime/composables.js",
      "#pages/composables": "./dist/pages/runtime/composables.js"
    },
    "types": "./types.d.ts"
  }
}
