{
  "name": "@nuxt/kit",
  "version": "5.0.0-0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/nuxt/nuxt.git",
    "directory": "packages/kit"
  },
  "homepage": "https://nuxt.com/docs/4.x/api/kit",
  "description": "Toolkit for authoring modules and interacting with Nuxt",
  "license": "MIT",
  "type": "module",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./package.json": "./package.json"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "prepack": "tsdown",
    "build": "tsdown",
    "test:attw": "node ../../scripts/test-attw.ts"
  },
  "dependencies": {
    "c12": "catalog:build",
    "consola": "catalog:build",
    "defu": "catalog:build",
    "destr": "catalog:build",
    "errx": "catalog:build",
    "exsolve": "catalog:build",
    "ignore": "catalog:build",
    "jiti": "catalog:build",
    "klona": "catalog:build",
    "mlly": "catalog:build",
    "nostics": "catalog:build",
    "nypm": "catalog:build",
    "ohash": "catalog:build",
    "pathe": "catalog:build",
    "pkg-types": "catalog:build",
    "rc9": "catalog:build",
    "scule": "catalog:build",
    "std-env": "catalog:build",
    "tinyglobby": "catalog:build",
    "ufo": "catalog:build",
    "unctx": "catalog:build",
    "untyped": "catalog:build",
    "verkit": "catalog:build"
  },
  "devDependencies": {
    "@nuxt/schema": "workspace:*",
    "hookable": "catalog:app-runtime",
    "nitro": "catalog:nitro-runtime",
    "nitropack": "catalog:dev",
    "tsdown": "catalog:dev",
    "unimport": "catalog:build",
    "vite": "catalog:vite",
    "vitest": "catalog:dev",
    "webpack": "catalog:webpack"
  },
  "engines": {
    "node": ">=18.12.0"
  },
  "publishConfig": {
    "exports": {
      ".": "./dist/index.mjs",
      "./package.json": "./package.json"
    },
    "types": "./dist/index.d.mts"
  }
}
