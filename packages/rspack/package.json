{
  "name": "@nuxt/rspack-builder",
  "version": "5.0.0-0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/nuxt/nuxt.git",
    "directory": "packages/rspack"
  },
  "description": "rspack bundler for Nuxt",
  "homepage": "https://nuxt.com",
  "license": "MIT",
  "type": "module",
  "types": "./src/index.ts",
  "imports": {
    "#vue-module-identifier": "./src/loaders/vue-module-identifier.ts"
  },
  "exports": {
    ".": "./src/index.ts",
    "./package.json": "./package.json"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "prepack": "tsdown",
    "build": "tsdown",
    "test:attw": "node ../../scripts/test-attw.ts"
  },
  "dependencies": {
    "@nuxt/friendly-errors-webpack-plugin": "catalog:webpack",
    "@nuxt/kit": "workspace:*",
    "@rsbuild/core": "catalog:webpack",
    "@vue/compiler-sfc": "catalog:vue",
    "autoprefixer": "catalog:build",
    "css-loader": "catalog:webpack",
    "css-minimizer-webpack-plugin": "catalog:webpack",
    "cssnano": "catalog:build",
    "defu": "catalog:build",
    "esbuild-loader": "catalog:webpack",
    "escape-string-regexp": "catalog:build",
    "exsolve": "catalog:build",
    "file-loader": "catalog:webpack",
    "jiti": "catalog:build",
    "knitwork": "catalog:build",
    "memfs": "catalog:webpack",
    "mini-css-extract-plugin": "catalog:webpack",
    "mlly": "catalog:build",
    "ohash": "catalog:build",
    "pathe": "catalog:build",
    "pify": "catalog:webpack",
    "postcss": "catalog:build",
    "postcss-import": "catalog:build",
    "postcss-import-resolver": "catalog:build",
    "postcss-loader": "catalog:build",
    "postcss-url": "catalog:build",
    "pug-plain-loader": "catalog:webpack",
    "raw-loader": "catalog:webpack",
    "rolldown-string": "catalog:vite",
    "rspack-vue-loader": "catalog:vue",
    "seroval": "catalog:build",
    "time-fix-plugin": "catalog:webpack",
    "tinyglobby": "catalog:build",
    "ts-checker-rspack-plugin": "catalog:webpack",
    "ufo": "catalog:build",
    "unenv": "catalog:build",
    "unplugin": "catalog:build",
    "url-loader": "catalog:webpack",
    "vue-bundle-renderer": "catalog:build",
    "webpack-bundle-analyzer": "catalog:webpack",
    "webpackbar": "catalog:webpack"
  },
  "devDependencies": {
    "@nuxt/schema": "workspace:*",
    "@types/webpack-bundle-analyzer": "catalog:dev",
    "h3": "1.15.11",
    "h3-next": "catalog:dev",
    "rollup": "catalog:dev",
    "tsdown": "catalog:dev",
    "vue": "catalog:app-runtime"
  },
  "peerDependencies": {
    "nuxt": "workspace:*",
    "vue": "^3.3.4"
  },
  "engines": {
    "node": "^22.12.0 || ^24.11.0 || >=26.0.0"
  },
  "publishConfig": {
    "exports": {
      ".": "./dist/index.mjs",
      "./dist/*": "./dist/*",
      "./package.json": "./package.json"
    },
    "types": "./dist/index.d.mts",
    "imports": {
      "#vue-module-identifier": "./dist/loaders/vue-module-identifier.mjs"
    }
  }
}
